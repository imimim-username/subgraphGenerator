# ── Etherscan API keys ────────────────────────────────────────────────────────
# Required for:
#   - Fetching contract ABIs from block explorers
#   - Auto-detecting contract deployment blocks (startBlock) during generation
#
# The unified key covers most chains (mainnet, Arbitrum, Base, Polygon, …)
# via the Etherscan v2 API.  Get yours at https://etherscan.io/myapikey
# (free tier is sufficient).
ETHERSCAN_API_KEY=

# Optimism (OP Mainnet) is NOT covered by the unified v2 API for the
# getcontractcreation endpoint.  A separate key from the Optimism Etherscan
# is required for startBlock auto-detection on Optimism contracts.
# Get yours at https://optimistic.etherscan.io/myapikey
OPTIMISM_ETHERSCAN_API_KEY=

# Arbitrum — the unified ETHERSCAN_API_KEY covers Arbitrum, but this legacy
# per-network key is also accepted for ABI fetching.
ARBITRUM_ETHERSCAN_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Debugging ─────────────────────────────────────────────────────────────────
# Set to 1, true, or yes to show full tracebacks on errors
DEBUG=
