# ── Etherscan API key ─────────────────────────────────────────────────────────
# Required for:
#   - Fetching contract ABIs from block explorers
#   - Auto-detecting contract deployment blocks (startBlock) during generation
#
# One key covers most chains (mainnet, Arbitrum, Base, Polygon, …) via the
# Etherscan v2 unified API.  Get yours at https://etherscan.io/myapikey
# (free tier is sufficient).
ETHERSCAN_API_KEY=

# Legacy per-network keys — still accepted for ABI fetching on those networks,
# but ETHERSCAN_API_KEY above is preferred for most use cases.
OPTIMISM_ETHERSCAN_API_KEY=
ARBITRUM_ETHERSCAN_API_KEY=

# ── RPC API key (Alchemy) ─────────────────────────────────────────────────────
# Used as a fallback for startBlock auto-detection when Etherscan lookups fail
# (e.g. Optimism, which is not supported by the Etherscan v2 unified API for
# contract creation queries).
# The same key works across all chains — only the base URL changes per chain
# (e.g. https://opt-mainnet.g.alchemy.com/v2/ for Optimism).
# Get yours at https://dashboard.alchemy.com/ (free tier is sufficient).
RPC_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Debugging ─────────────────────────────────────────────────────────────────
# Set to 1, true, or yes to show full tracebacks on errors
DEBUG=
