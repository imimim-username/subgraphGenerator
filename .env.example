# ── Etherscan API key ─────────────────────────────────────────────────────────
# Required for:
#   - Fetching contract ABIs from block explorers
#   - Auto-detecting contract deployment blocks (startBlock) during generation
#
# One key covers ALL supported networks via the Etherscan v2 unified API.
# Get yours at https://etherscan.io/myapikey (free tier is sufficient).
ETHERSCAN_API_KEY=

# Legacy per-network keys (still accepted for ABI fetching on those networks,
# but ETHERSCAN_API_KEY above is preferred and covers everything).
OPTIMISM_ETHERSCAN_API_KEY=
ARBITRUM_ETHERSCAN_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Debugging ─────────────────────────────────────────────────────────────────
# Set to 1, true, or yes to show full tracebacks on errors
DEBUG=
